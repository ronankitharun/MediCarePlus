RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
VITE_RAZORPAY_KEY_ID=

# Email Configuration (Current Server-side - may not work on Firebase Hosting)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
ADMIN_EMAIL=

# EmailJS Configuration (Client-side - Recommended for Firebase Hosting)
# Get these from https://dashboard.emailjs.com/
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# Firebase Config (already set up)
# GEMINI_API_KEY is also available
